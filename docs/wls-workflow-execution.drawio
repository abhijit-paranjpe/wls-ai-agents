    <diagram id="wls-workflow-cross-turn" name="Cross-Turn Conversation Lifecycle">
        <mxGraphModel dx="1642" dy="916" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="Cross-Turn Conversation Lifecycle for a PATCHING Workflow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="470" y="20" width="1260" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="Unlike the chess example, the WebLogic chatbot should persist and resume on the next /chat turn rather than block a request thread waiting for human input." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="250" y="58" width="1700" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="User / Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="120" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="ChatBotEndpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="380" y="120" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="WorkflowOrchestratorService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="730" y="120" width="260" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="WorkflowStateStore + History" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1130" y="120" width="260" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="Turn 1&#xa;User: &#39;Apply patches to prod_domain&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="40" y="240" width="240" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="Parse request&#xa;merge TaskContext&#xa;load persisted workflow context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="350" y="240" width="260" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="22" value="Detect new workflow request&#xa;resolve target&#xa;transition to AWAITING_CONFIRMATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="710" y="240" width="300" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="23" value="Persist workflow state:&#xa;workflowType=PATCHING&#xa;workflowStep=CONFIRMATION_REQUIRED&#xa;workflowStatus=AWAITING_USER_CONFIRMATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1090" y="230" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="24" value="Assistant reply:&#xa;&#39;Confirm you want me to patch prod_domain. Reply yes to proceed or no to cancel.&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="350" y="380" width="700" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="Turn 2&#xa;User: &#39;yes&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="70" y="540" width="180" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="Reload workflow by conversationId&#xa;recognize short reply as a workflow continuation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="340" y="530" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="Transition to EXECUTING&#xa;invoke bounded execution subflow&#xa;(stop - apply - start - verify)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="700" y="530" width="320" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="Persist intermediate step history and final terminal state&#xa;COMPLETED / FAILED / CANCELLED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1090" y="535" width="320" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="34" value="Assistant reply includes workflow progress and factual execution results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="420" y="670" width="600" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="40" value="Turn 3+&#xa;User: &#39;What is the status?&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="50" y="810" width="220" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="41" value="Load latest workflow record / history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="350" y="805" width="250" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="42" value="Render status / history response without restarting execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="700" y="800" width="320" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="Return latest step, terminal status, and audit summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1090" y="800" width="320" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="44" value="If the original request omitted the domain, insert an extra cross-turn stage:&#xa;AWAITING_DOMAIN -&gt; user supplies domain -&gt; AWAITING_CONFIRMATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1510" y="355" width="430" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="Key design principle:&#xa;Persist and resume across turns.&#xa;Do not keep a workflow thread blocked waiting for a chat reply." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1510" y="610" width="430" height="100" as="geometry"/>
                </mxCell>
